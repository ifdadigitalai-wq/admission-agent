generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum LeadStatus {
  PENDING
  CONTACTED
  CONVERTED
  REJECTED
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
  posts Post[]
}

model Post {
  id        Int     @id @default(autoincrement())
  title     String
  content   String?
  published Boolean @default(false)
  author    User    @relation(fields: [authorId], references: [id])
  authorId  Int
}

model Faq {
  id        String                      @id @default(uuid())
  question  String
  answer    String
  embedding Unsupported("vector(768)")?
}

model Lead {
  id        String     @id @default(uuid())
  name      String
  email     String
  phone     String
  course    String
  source    String     @default("WEBSITE")
  status    LeadStatus @default(PENDING)
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

enum AppointmentType {
  CALL
  VISIT
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model Appointment {
  id        String            @id @default(uuid())
  name      String
  email     String
  phone     String
  course    String?
  type      AppointmentType
  date      String
  time      String
  status    AppointmentStatus @default(SCHEDULED)
  createdAt DateTime          @default(now())
}

model Admin {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String // bcrypt hashed
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Conversation {
  id        String                @id @default(uuid())
  sessionId String                @unique
  userName  String?
  userEmail String?
  userPhone String?
  messages  ConversationMessage[] // Relation updated in the message model below
  unread    Int                   @default(0)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
}

model ConversationMessage {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // "user" | "bot"
  content        String
  createdAt      DateTime     @default(now())
}

model WhatsAppSession {
  id             String   @id @default(uuid())
  phone          String   @unique
  leadInfo       Json     @default("{}")
  isEnrolling    Boolean  @default(false)
  isScheduling   Boolean  @default(false)
  schedulingStep String?
  scheduleData   Json     @default("{}")
  availableDates Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Course {
  id          String   @id @default(uuid())
  name        String
  description String
  image       String // URL to course image
  link        String // Course detail page URL
  duration    String
  fee         String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}
