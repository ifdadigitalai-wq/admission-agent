generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum LeadStatus {
  PENDING
  CONTACTED
  CONVERTED
  REJECTED
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
  posts Post[]
}

model Post {
  id        Int     @id @default(autoincrement())
  title     String
  content   String?
  published Boolean @default(false)
  author    User    @relation(fields: [authorId], references: [id])
  authorId  Int
}

model Faq {
  id        String                      @id @default(uuid())
  question  String
  answer    String
  source    String? // "seed" | "upload:<fileId>"
  embedding Unsupported("vector(768)")?
}

model KnowledgeFile {
  id         String   @id @default(uuid())
  filename   String
  fileType   String // txt, csv, json, pdf
  fileSize   Int
  entries    Int      @default(0)
  status     String   @default("processing") // processing, completed, failed
  error      String?
  uploadedBy String
  createdAt  DateTime @default(now())
}

model Lead {
  id        String     @id @default(uuid())
  name      String
  email     String
  phone     String
  course    String
  status    LeadStatus @default(PENDING)
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

enum AppointmentType {
  CALL
  VISIT
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model Appointment {
  id        String            @id @default(uuid())
  name      String
  email     String
  phone     String
  course    String?
  type      AppointmentType
  date      String
  time      String
  status    AppointmentStatus @default(SCHEDULED)
  createdAt DateTime          @default(now())
}

enum AdminRole {
  ADMIN
  COUNSELOR
  TELECALLER // Existing
  MANAGER // Existing
  SUPPORT
  MANAGEMENT // New
  SALES // New
  TELE_CALLER // New (Mapped from "Tele caller")
  DEVELOPER // New
  MARKETING // New
}

model Admin {
  id             String    @id @default(uuid())
  name           String
  email          String    @unique
  password       String // bcrypt hashed
  role           AdminRole @default(ADMIN)
  contactNumber  String? // Added for the Members UI
  profilePicture String? // Added for the Members UI (URL or path to the image)
  createdAt      DateTime  @default(now())
}

model Conversation {
  id        String                @id @default(uuid())
  sessionId String                @unique
  userName  String?
  userEmail String?
  userPhone String?
  messages  ConversationMessage[] // Relation updated in the message model below
  unread    Int                   @default(0)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
}

model ConversationMessage {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // "user" | "bot"
  content        String
  createdAt      DateTime     @default(now())
}

model Course {
  id          String   @id @default(uuid())
  name        String
  description String?
  duration    String?
  fees        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
